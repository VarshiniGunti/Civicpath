    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^8.1.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "vite": "^5.3.1",
    "vitest": "^4.1.5"
