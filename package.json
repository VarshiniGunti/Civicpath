{
  "name": "civicpath-ai",
  "version": "1.0.0",
  "description": "CivicPath AI - Your Intelligent Guide to Civil Engagement and Elections",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n Vite,API -c cyan,magenta \"vite\" \"node server.js\"",
