    "start": "node server.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,html,css}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^0.7.0",
